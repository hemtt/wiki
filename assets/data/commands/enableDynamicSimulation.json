{
  "argument_loc": "Global",
  "description": "Enables or disables [[Arma 3: Dynamic Simulation]] for an object or group.\n\n{{Feature|important|Dynamic simulation for AI units operates on [[Group]]s:\n<sqf>\n_unit enableDynamicSimulation true; // Does not work\ngroup _unit enableDynamicSimulation true; // Works\n</sqf>\nIt is not possible to enable dynamic simulation for groups that contain a player unit.\n}}\n\n{{Feature|informative|This command has no effect on ''mines''!}}",
  "effect_loc": "Local",
  "examples": [
    "<sqf>_myObject enableDynamicSimulation true;</sqf>"
  ],
  "groups": [
    "Dynamic Simulation"
  ],
