{
  "argument_loc": "Global",
  "description": "Returns all magazines of given turret. Use turret path [-1] for driver's turret. Alternatively, use [[magazinesAllTurrets]].\n{{Feature|informative|When main syntax is used, command excludes empty magazines for driver turret [-1] but returns empty magazines for all the other turrets.}}",
  "effect_loc": "Unspecified",
  "examples": [
    "<sqf>_mags = vehicle player magazinesTurret [0, 0];</sqf>",
    "<sqf>_mags = _tank magazinesTurret [[0], false];</sqf>"
  ],
  "groups": [
    "Turrets"
  ],
  "name": "magazinesTurret",
  "problem_notes": [],
