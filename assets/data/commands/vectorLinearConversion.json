{
  "argument_loc": "Unspecified",
  "description": "Interpolates vector between the given ''vectorFrom'' and ''vectorTo'' value according to the given range value.",
  "effect_loc": "Unspecified",
  "examples": [
    "<sqf>vectorLinearConversion [0, 1, 0.5, [0,0,0], [25,50,100], false];\t// [12.5,25,50]</sqf>",
    "<sqf>vectorLinearConversion [0, 1, 100, [0,0,0], [25,50,100], true];\t// [25,50,100]</sqf>",
    "<sqf>vectorLinearConversion [0, 1, 100, [0,0,0], [25,50,100], false];\t// [2500,5000,10000]</sqf>"
  ],
  "groups": [
    "Math - Vectors"
  ],
  "id": "vectorLinearConversion",
  "name": "vectorLinearConversion",
  "problem_notes": [],
  "see_also": [
    "linearConversion",
    "bezierInterpolation",
    "matrixMultiply",
    "matrixTranspose"
  ],
  "since": {},
  "status": "Passed",
  "syntax": [
    {
      "call": {
        "Unary": [
          "rangeFrom",
          "rangeTo",
          "rangeValue",
          "vectorFrom",
          "vectorTo",
          "clip"
        ]
      },
      "ret": {
        "desc": "interpolated vector",
        "type": "Vector3d"
      },
      "right": {
        "Array": [
          {
            "Item": {
              "desc": "start \"from\" range",
              "name": "rangeFrom",
              "type": "Number"
            }
          },
          {
            "Item": {
              "desc": "end \"to\" range",
              "name": "rangeTo",
              "type": "Number"
            }
          },
          {
            "Item": {
              "desc": "variable range value",
              "name": "rangeValue",
              "type": "Number"
            }
          },
          {
            "Item": {
              "desc": "start \"from\" vector",
              "name": "vectorFrom",
              "type": "Vector3d"
            }
          },
          {
            "Item": {
              "desc": "end \"to\" vector",
              "name": "vectorTo",
              "type": "Vector3d"
            }
          },
          {
            "Item": {
              "default": "false",
              "desc": "if [[true]], range value will be clipped to stay within \"from\" - \"to\" range",
              "name": "clip",
              "optional": true,
              "type": "Boolean"
            }
          }
        ]
      }
    }
  ]
}