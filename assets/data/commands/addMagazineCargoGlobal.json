  "syntax": [
    {
      "call": {
        "Binary": [
          "vehicleName",
          [
            "magazineName",
            "count"
          ]
        ]
      },
      "left": {
        "Item": {
          "desc": "vehicle to add the magazines to",
          "name": "vehicleName",
          "type": "Object"
        }
      },
      "ret": {
        "type": "Nothing"
