{
  "argument_loc": "Unspecified",
  "description": "Sets tooltip on the item with the given row and column of [[CT_LISTNBOX]].\n{{Feature|important|\nBy default, tooltips are added for all columns no matter what column index is provided.\nThis behaviour can be overwritten since {{GVI|arma3|2.02}} by setting the control's property {{hl|tooltipPerColumn}} to [[true]].\nSee [[CT_LISTNBOX#tooltipPerColumn|CT_LISTNBOX documentation]].\n}}",
  "effect_loc": "Unspecified",
  "examples": [
    "<sqf>lnbSetTooltip [1234, [1,0], \"tip\"];</sqf>",
    "<sqf>_ctrl lnbSetTooltip [[3,0], \"top\"];</sqf>"
  ],
