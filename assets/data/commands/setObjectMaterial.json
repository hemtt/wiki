  "examples": [
    "<sqf>\ncar setObjectMaterial [0,\"A3\\Structures_F\\Data\\Windows\\window_set.rvmat\"];\ncar setObjectMaterial [1,\"A3\\Structures_F\\Data\\Windows\\window_set.rvmat\"];\n</sqf>"
  ],
  "groups": [
    "Object Manipulation"
  ],
  "id": "setObjectMaterial",
  "name": "setObjectMaterial",
  "problem_notes": [],
  "see_also": [
