{
  "argument_loc": "Local",
  "description": "Order the given unit(s) to watch the given position or target (without radio messages). Use [[objNull]] as the target to order a unit to stop watching a position/target.",
  "effect_loc": "Global",
  "examples": [
    "<sqf>_soldierOne doWatch markerPos \"MarkerMoveOne\";</sqf>\n\nThe unit named \"soldierOne\" will watch the position where the marker \"MarkerMoveOne\" is placed.",
    "<sqf>_soldierOne doWatch _eastSoldier;</sqf>\n\nThe unit named \"soldierOne\" will watch the unit named \"eastSoldier\"."
  ],
  "groups": [
    "Unit Control"
  ],
  "id": "doWatch",
  "name": "doWatch",
