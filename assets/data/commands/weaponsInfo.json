{
  "argument_loc": "Unspecified",
  "description": "Returns entity's weapons information including weapon index and firemode.",
  "effect_loc": "Unspecified",
  "examples": [
    "Find weapon with FullAuto firemode and switch to it: <sqf>\nprivate _weapons = player weaponsInfo [currentMuzzle player, true];\nprivate _found = _weapons findIf { _x select 4 == \"FullAuto\" };\nif (_found > -1) then { action [\"SwitchWeapon\", player, player, _weapons select _found select 0] };\n</sqf>"
  ],
  "groups": [
    "Weapons"
  ],
  "id": "weaponsInfo",
  "name": "weaponsInfo",
  "problem_notes": [],
  "see_also": [
    "weaponState",
    "weaponReloadingTime",
    "action"
  ],
  "since": {},
  "status": "Passed",
  "syntax": [
    {
      "call": {
        "Binary": [
          "unit",
          [
            "weaponOrMuzzle",
            "onlyLoaded"
          ]
        ]
      },
      "left": {
        "Item": {
          "desc": "person",
          "name": "unit",
          "type": "Object"
        }
      },
      "ret": {
        "type": {
          "ArrayUnsized": {
            "value": {
              "ArraySized": [
                {
                  "default": null,
                  "desc": "internal weapon index (changes frequently) used with \"SwitchWeapon\" and \"UseWeapon\" [[action]]s",
                  "name": "weaponIndex",
                  "since": null,
                  "type": "Number"
                },
                {
                  "default": null,
                  "desc": "[[true]] if this weapon is currently selected",
                  "name": "isSelected",
                  "since": null,
                  "type": "Boolean"
                },
                {
                  "default": null,
                  "desc": "weapon name",
                  "name": "weaponName",
                  "since": null,
                  "type": "String"
                },
                {
                  "default": null,
                  "desc": "muzzle name",
                  "name": "muzzleName",
                  "since": null,
                  "type": "String"
                },
                {
                  "default": null,
                  "desc": "firemode that is set for this 'weaponIndex'",
                  "name": "firemode",
                  "since": null,
                  "type": "String"
                },
                {
                  "default": null,
                  "desc": "name of the loaded magazine or \"\"",
                  "name": "magazineName",
                  "since": null,
                  "type": "String"
                },
                {
                  "default": null,
                  "desc": "magazine ammo count or -1",
                  "name": "ammoCount",
                  "since": null,
                  "type": "Number"
                },
                {
                  "default": null,
                  "desc": "[[true]] if this muzzle is considered primary by the engine (Since Arma 3 2.14)",
                  "name": "isPrimary",
                  "since": null,
                  "type": "Boolean"
                }
              ]
            }
          }
        }
      },
      "right": {
        "Array": [
          {
            "Item": {
              "desc": "name of the weapon or muzzle (returns whichever matches first) or \"\" to return all weapons",
              "name": "weaponOrMuzzle",
              "type": "String"
            }
          },
          {
            "Item": {
              "default": "false",
              "desc": "[[true]] to return loaded weapons only",
              "name": "onlyLoaded",
              "optional": true,
              "type": "Boolean"
            }
          }
        ]
      }
    }
  ]
}