    "getPosASLVisual",
    "getPosATLVisual",
    "visiblePositionASL",
    "visiblePosition",
    "position",
    "getPosATL",
    "getPosASL",
    "getPosASLW"
  ],
  "status": "Passed",
  "syntax": [
    {
      "call": {
        "Binary": [
          "object",
          [
            "distance",
            "direction"
          ]
        ]
      },
      "left": {
        "Item": {
          "desc": "object",
          "name": "object",
          "type": "Object"
        }
      },
      "ret": {
        "type": "Position3dAGL"
      },
      "right": {
        "Array": [
          {
            "Item": {
