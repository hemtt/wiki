    {
      "call": {
        "Unary": [
          "className",
          "position",
          "sizeX",
          "sizeY"
        ]
      },
      "ret": {
        "type": "Location"
      },
      "right": {
        "Array": [
          {
            "Item": {
              "name": "className",
              "type": "String"
            }
          },
          {
            "Item": {
              "name": "position",
              "type": {
                "OneOf": [
                  {
                    "desc": null,
                    "since": null,
                    "type": "Position2d"
                  },
                  {
                    "desc": null,
                    "since": null,
                    "type": "Position3d"
                  },
                  {
                    "desc": null,
                    "since": null,
                    "type": "Object"
                  }
                ]
              }
            }
          },
          {
            "Item": {
              "desc": "in meters",
              "name": "sizeX",
              "type": "Number"
            }
          },
          {
            "Item": {
              "desc": "in meters",
              "name": "sizeY",
              "type": "Number"
            }
          }
        ]
      }
    },
    {
      "call": {
        "Unary": [
          "location"
        ]
      },
      "ret": {
        "desc": "a script-editable location",
        "type": "Location"
      },
      "right": {
        "Array": [
          {
            "Item": {
              "desc": "a terrain's location. If a scripted location is provided, it is simply returned",
              "name": "location",
              "type": "Location"
            }
          }
        ]
      },
      "since": {
        "arma3": "2.10"
      }
    }
  ]
}