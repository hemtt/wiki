  "examples": [
    "<sqf>private _randomUserInfo = getUserInfo selectRandom allUsers;</sqf>",
    "<sqf>\n_userInfo params [\"_playerID\", \"_ownerId\", \"_playerUID\", \"_profileName\", \"_displayName\", \"_steamName\", \"_clientState\", \"_isHC\", \"_adminState\", \"_networkInfo\", \"_unit\"];\n_networkInfo params [\"_avgPing\", \"_avgBandwidth\", \"_desync\"];\n</sqf>",
    "<sqf>private _myInfo = getUserInfo getPlayerID player; // this particular example only works if player is server host</sqf>"
  ],
