{
  "argument_loc": "Local",
  "description": "Adds the next frame to the map animation.",
  "effect_loc": "Local",
  "examples": [
    "<sqf>\n_map ctrlMapAnimAdd [1, 0.1, getMarkerPos \"anim1\"];\nctrlMapAnimCommit _map;\n</sqf>",
    "Center map on player:\n<sqf>\n_ctrl ctrlMapAnimAdd [0, 0.05, player];\nctrlMapAnimCommit _ctrl;\n</sqf>",
    "<sqf>\n_map ctrlMapSetPosition [];\n_map ctrlMapAnimAdd [1, 0.1, getMarkerPos \"anim1\"];\nctrlMapAnimCommit _map;\n</sqf>"
  ],
  "groups": [
    "GUI Control - Map"
  ],
  "name": "ctrlMapAnimAdd",
  "problem_notes": [
    "When used on a [[CT_MAP]] that was created dynamically the target position could be offset. Use [[ctrlMapSetPosition]] before adding animation (Example 3)."
  ],
  "see_also": [
    "ctrlMapSetPosition",
    "mapAnimAdd",
    "mapAnimClear",
    "mapAnimCommit",
    "mapAnimDone",
    "ctrlMapAnimClear",
    "ctrlMapAnimCommit",
    "ctrlMapAnimDone"
  ],
  "status": "Passed",
