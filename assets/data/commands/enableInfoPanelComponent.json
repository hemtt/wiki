  "description": "Controls availability of component to given object info panel.",
  "effect_loc": "Unspecified",
  "examples": [
    "<sqf>\n// enables slingload assistant on player's vehicle right panel at driver position\n[vehicle player, [-1]] enableInfoPanelComponent [\"VehicleSystemsDisplayManagerComponentRight\", \"SlingLoadDisplay\", true];\n</sqf>"
  ],
  "groups": [
    "Custom Panels"
  ],
  "id": "enableInfoPanelComponent",
