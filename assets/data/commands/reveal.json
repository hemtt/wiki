{
  "argument_loc": "Global",
  "description": "Reveals a target to a [[group]]. If ''toWhom'' is a unit, unit's group is considered. If ''toWhom'' is a vehicle, vehicle commander's group is considered.  The [[knowsAbout|knowledge value]] will be set to the highest level any unit of the revealing side has about the revealed target. If the revealing side has ''no'' knowledge about the revealed target, the value will be set to 1.\n\n{{Feature | informative | The knowledge level can only be increased by this command, not decreased. Use [[forgetTarget]] first if you need to decrease value.}}",
  "effect_loc": "Local",
  "examples": [
    "<sqf>_soldierOne reveal _soldierTwo; // soldierOne knowsAbout information about soldierTwo is updated</sqf>",
    "<sqf>player reveal cursorObject; // player knowsAbout information about object under cursor is updated</sqf>",
    "<sqf>_soldierOne reveal [_soldierTwo, 1.5];</sqf>"
  ],
  "groups": [
    "Object Manipulation"
  ],
  "name": "reveal",
  "problem_notes": [],
  "see_also": [
    "nearTargets",
    "knowsAbout",
    "forgetTarget",
    "ignoreTarget"
  ],
  "status": "Passed",
