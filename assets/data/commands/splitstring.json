{
  "argument_loc": "Unspecified",
  "description": "Splits the provided '''ANSI''' string into an array of tokens according to given delimiters.\n{{Feature|informative|For Unicode support, see [[forceUnicode]].}}",
  "effect_loc": "Unspecified",
  "examples": [
    "<sqf>\n_str = \"- This, is a sample string.\" splitString \"-,. \"; // [\"This\",\"is\",\"a\",\"sample\",\"string\"]\n_str joinString \"#\"; // \"This#is#a#sample#string\"\n</sqf>",
    "<sqf>\n\"\\A3\\ui_f\\data\\map\\vehicleicons\\iconLogic_ca.paa\" splitString \"\\.\"; // [\"A3\",\"ui_f\",\"data\",\"map\",\"vehicleicons\",\"iconLogic_ca\",\"paa\"]\n</sqf>",
    "<sqf>\"1:2:3\" splitString \":\"; // [\"1\",\"2\",\"3\"]</sqf>",
    "<sqf>\"Japa is the best!\" splitString \"\" joinString \" \"; // \"J a p a   i s   t h e   b e s t !\"</sqf>",
    "<sqf>\n_cmd = currentMagazineDetail player; // \"9mm 16Rnd Mag(13/16)[id/cr:10000011/0]\"\n_cmd splitString \"([ ]/:)\"; // [\"9mm\",\"16Rnd\",\"Mag\",\"13\",\"16\",\"id\",\"cr\",\"10000011\",\"0\"]\n</sqf>",
    "Remove all \\r\\n from file:\n<sqf>loadFile \"somefile.txt\" splitString toString [13,10] joinString \" \";</sqf>"
  ],
  "groups": [
    "Strings"
  ],
