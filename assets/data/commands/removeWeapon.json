{
  "argument_loc": "Local",
  "description": "Remove weapon from a unit. The unit must be [[Multiplayer Scripting#Locality|local]] to the computer where command is executed.\nFor a global version of this command, see [[removeWeaponGlobal]].\n\n{{Feature|informative|\nIt is possible to create invalid combinations with this command (e.g attempting to remove a weapon that a unit does not possess).\nWhen doing so, application behaviour is undefined.\n}}",
  "effect_loc": "Global",
  "examples": [
    "<sqf>player removeWeapon \"BAF_L85A2_RIS_SUSAT\";</sqf>",
    "<sqf>An_2 removeWeapon \"M240_veh\";</sqf>"
  ],
  "groups": [
    "Unit Inventory",
    "Vehicle Inventory"
  ],
  "id": "removeWeapon",
  "name": "removeWeapon",
  "problem_notes": [],
  "see_also": [
    "removeWeaponGlobal",
    "addWeapon",
    "removeAllWeapons"
  ],
  "since": {},
  "status": "Passed",
  "syntax": [
    {
      "call": {
        "Binary": [
          "unit",
          "weapon"
        ]
      },
      "left": {
        "Item": {
          "desc": "unit or vehicle",
          "name": "unit",
          "type": "Object"
        }
      },
      "ret": {
        "type": "Nothing"
      },
      "right": {
        "Item": {
          "desc": "weapon class name",
          "name": "weapon",
          "type": "String"
        }
      }
    },
    {
      "call": {
        "Binary": [
          "object",
          [
            "weapon",
            "autoselect"
          ]
        ]
      },
      "left": {
        "Item": {
          "desc": "unit or vehicle",
          "name": "object",
          "type": "Object"
        }
      },
      "ret": {
        "type": "Nothing"
      },
      "right": {
        "Array": [
          {
            "Item": {
              "desc": "weapon class name",
              "name": "weapon",
              "type": "String"
            }
          },
          {
            "Item": {
              "default": "true",
              "desc": "[[false]] to abort weapon autoselection when removing primary weapon.",
              "name": "autoselect",
              "optional": true,
              "type": "String"
            }
          }
        ]
      },
      "since": {
        "arma3": "2.20"
      }
    }
  ]
}